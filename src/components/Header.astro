---
const nav = [
  {
    label: "Home",
    href: "/",
    children: [
      { label: "Golf Course", href: "/golf-course" },
      { label: "StoneHouse Lounge", href: "/stonehouse-lounge" },
    ],
  },
  {
    label: "Rates",
    href: "/rates",
    children: [
      { label: "Memberships", href: "/memberships" },
      { label: "Event Pricing", href: "/event-pricing" },
    ],
  },
  {
    label: "Events",
    href: "/events",
    children: [
      { label: "Calendar", href: "/calendar" },
      { label: "Central Counties", href: "/events/central-counties" },
      { label: "Fall Classic", href: "/events/fall-classic" },
      { label: "June Invitational", href: "/events/june-invitational" },
      { label: "Senior Invitational", href: "/events/senior-invitational" },
      { label: "Spring Classic", href: "/events/spring-classic" },
    ],
  },
  {
    label: "History",
    href: "/history",
    children: [
      { label: "Ladies' Club Champions", href: "/history/ladies-club-champions" },
      { label: "Men's Club Champions", href: "/history/mens-club-champions" },
      { label: "Seniors Club Champions", href: "/history/seniors-club-champions" },
      { label: "ALCC Aces", href: "/history/alcc-aces" },
      { label: "Twilight League", href: "/history/twilight-league" },
      { label: "Prominent Individuals in ALCC History", href: "/history/prominent-individuals" },
      { label: "Route 22 Cup", href: "/history/route-22-cup" },
    ],
  },
  { label: "Members", href: "/members" },
  { label: "Pro Shop", href: "/pro-shop" },
  { label: "Contact Us", href: "/contact" },
];
---

<div class="top-bar">
  <div class="container top-bar__inner">
    <div class="top-bar__contact">
      <a href="tel:18145424343">(814) 542-4343</a>
      <a href="mailto:golf.alcc@gmail.com">golf.alcc@gmail.com</a>
    </div>
    <div class="top-bar__social">
      <a href="https://www.facebook.com/americanlegioncountryclub/" aria-label="Facebook" target="_blank" rel="noopener">Facebook</a>
      <a href="https://www.instagram.com/alccgolfpa/" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
    </div>
  </div>
</div>
<div class="stripe-flag"></div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <img class="brand__logo" src="/images/home/logo.webp" alt="American Legion Country Club" />
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="primary-nav">
      <span></span><span></span><span></span>
      <span class="sr-only">Menu</span>
    </button>

    <nav class="primary-nav" id="primary-nav">
      <ul>
        {nav.map((item) => (
          <li class:list={["nav-item", { "has-children": item.children }]}>
            <a href={item.href}>{item.label}</a>
            {item.children && (
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li><a href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <a class="btn btn--red nav-cta" href="tel:18145424343">Call Now</a>
    </nav>
  </div>
</header>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .top-bar {
    background: var(--color-blue-dark);
    color: var(--color-white);
    font-size: 0.85rem;
  }
  .top-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1.25rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .top-bar a { color: var(--color-white); opacity: 0.9; }
  .top-bar a:hover { opacity: 1; text-decoration: underline; }
  .top-bar__contact, .top-bar__social { display: flex; gap: 1.25rem; }

  .site-header {
    background: var(--color-white);
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem;
  }

  .brand { display: flex; align-items: center; }
  .brand__logo { height: 52px; width: auto; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle span {
    width: 26px;
    height: 3px;
    background: var(--color-blue-dark);
    border-radius: 2px;
  }

  .primary-nav > ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .primary-nav { display: flex; align-items: center; gap: 1.5rem; }

  .nav-item { position: relative; }
  .nav-item > a {
    display: block;
    padding: 0.85rem 0.9rem;
    color: var(--color-blue-dark);
    font-family: var(--font-heading);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    font-weight: 600;
  }
  .nav-item > a:hover { color: var(--color-red); text-decoration: none; }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    background: var(--color-white);
    border-top: 3px solid var(--color-red);
    box-shadow: var(--shadow-md);
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    z-index: 50;
  }
  .nav-item.has-children:hover .dropdown,
  .nav-item.has-children:focus-within .dropdown {
    display: block;
  }
  .dropdown li a {
    display: block;
    padding: 0.6rem 1.1rem;
    font-size: 0.85rem;
    color: var(--color-ink);
    white-space: normal;
  }
  .dropdown li a:hover { background: var(--color-off-white); color: var(--color-red); text-decoration: none; }

  .nav-cta { white-space: nowrap; }

  @media (max-width: 980px) {
    .nav-toggle { display: flex; }
    .primary-nav {
      position: fixed;
      inset: 0 0 0 30%;
      background: var(--color-white);
      flex-direction: column;
      align-items: stretch;
      padding: 1.5rem;
      transform: translateX(100%);
      transition: transform 0.25s ease;
      overflow-y: auto;
      box-shadow: var(--shadow-md);
    }
    .primary-nav.is-open { transform: translateX(0); }
    .primary-nav > ul { flex-direction: column; align-items: stretch; gap: 0; width: 100%; }
    .nav-item > a { padding: 0.85rem 0.25rem; border-bottom: 1px solid var(--color-gray-light); }
    .dropdown {
      display: block;
      position: static;
      border-top: none;
      box-shadow: none;
      padding-left: 1rem;
      border-left: 3px solid var(--color-red);
    }
    .nav-cta { margin-top: 1rem; text-align: center; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });
</script>
