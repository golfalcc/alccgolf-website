---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  size?: "large" | "small";
  image?: string;
}
const { eyebrow, title, subtitle, ctaLabel, ctaHref, size = "large", image } = Astro.props;
---

<section
  class:list={["hero", { "hero--small": size === "small" }]}
  style={image ? `--hero-image: url(${image});` : undefined}
>
  <div class="container hero__inner">
    {eyebrow && <span class="eyebrow eyebrow--light">{eyebrow}</span>}
    <h1>{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    {ctaLabel && ctaHref && (
      <a class="btn btn--red" href={ctaHref}>{ctaLabel}</a>
    )}
  </div>
</section>

<style>
  .hero {
    background:
      linear-gradient(120deg, rgba(4,30,66,0.88) 0%, rgba(10,49,97,0.78) 55%, rgba(179,25,66,0.55) 100%),
      var(--hero-image, none) center/cover no-repeat,
      var(--color-blue-dark);
    color: var(--color-white);
    padding: 6rem 0 5rem;
  }
  .hero--small { padding: 3.5rem 0 3rem; }
  .hero__inner { max-width: 760px; }
  .hero h1 { color: var(--color-white); }
  .eyebrow--light { color: #FFD966; }
  .hero__subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.9); max-width: 600px; }
</style>
