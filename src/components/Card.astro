---
interface Props {
  title: string;
  href: string;
  description?: string;
  imageLabel?: string;
  image?: string;
}
const { title, href, description, imageLabel, image } = Astro.props;
---

<a class="card card-link" href={href}>
  {image
    ? <img class="card__photo" src={image} alt={title} loading="lazy" />
    : <div class="card__image">{imageLabel ?? title}</div>
  }
  <div class="card__body">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    <span class="card__cta">Learn More &rarr;</span>
  </div>
</a>

<style>
  .card-link { color: inherit; }
  .card-link:hover { text-decoration: none; box-shadow: var(--shadow-md); transform: translateY(-2px); transition: 0.15s ease; }
  .card__photo {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .card__cta {
    color: var(--color-red);
    font-family: var(--font-heading);
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
</style>
