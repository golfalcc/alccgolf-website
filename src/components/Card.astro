---
interface Props {
  title: string;
  href: string;
  description?: string;
  imageLabel?: string;
  image?: string;
  imageFit?: 'cover' | 'contain';
  imageScale?: number;
}
const { title, href, description, imageLabel, image, imageFit = 'cover', imageScale = 0.85 } = Astro.props;
---

<a class="card card-link" href={href}>
  {image
    ? imageFit === 'contain'
      ? <div class="card__photo card__photo--contain"><img src={image} alt={title} loading="lazy" style={`max-width:${imageScale * 100}%;max-height:${imageScale * 100}%;`} /></div>
      : <img class="card__photo" src={image} alt={title} loading="lazy" />
    : <div class="card__image">{imageLabel ?? title}</div>
  }
  <div class="card__body">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    <span class="card__cta">Learn More &rarr;</span>
  </div>
</a>

<style>
  .card-link { color: inherit; }
  .card-link:hover { text-decoration: none; box-shadow: var(--shadow-md); transform: translateY(-2px); transition: 0.15s ease; }
  .card__photo {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .card__photo--contain {
    background: linear-gradient(135deg, var(--color-blue) 0%, var(--color-blue-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    aspect-ratio: 16 / 10;
  }
  .card__photo--contain img {
    object-fit: contain;
  }
  .card__cta {
    color: var(--color-red);
    font-family: var(--font-heading);
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
</style>
