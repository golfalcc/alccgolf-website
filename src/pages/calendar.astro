---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const events = [
  { name: "Spring Classic", window: "Last full weekend in April", href: "/events/spring-classic" },
  { name: "June Invitational", window: "Last full weekend in June", href: "/events/june-invitational" },
  { name: "Senior Invitational", window: "Late summer", href: "/events/senior-invitational" },
  { name: "Central Counties (CCGA)", window: "Per CCGA schedule", href: "/events/central-counties" },
  { name: "Fall Classic", window: "Late season (two-day weekend)", href: "/events/fall-classic" },
];
---

<BaseLayout title="Calendar" description="Calendar of events for American Legion Country Club.">
  <PageHero title="Calendar" subtitle="Live event calendar." />

  <section class="section">
    <div class="container">
      <div class="calendar-embed">
        <iframe
          src="https://localendar.com/public/alccgolf"
          title="ALCC Calendar of Events"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p><em>This calendar is embedded live from the club's existing
      Localendar account. Keep events current there, or replace the embed
      in <code>src/pages/calendar.astro</code> with another calendar
      provider if the club switches tools.</em></p>

      <h2 style="margin-top:2.5rem;">Quick Reference</h2>
      <table>
        <thead><tr><th>Event</th><th>Approximate Window</th><th></th></tr></thead>
        <tbody>
          {events.map((e) => (
            <tr>
              <td>{e.name}</td>
              <td>{e.window}</td>
              <td><a href={e.href}>Details &rarr;</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<style>
  .calendar-embed {
    position: relative;
    width: 100%;
    padding-top: 66%;
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-off-white);
  }
  .calendar-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
