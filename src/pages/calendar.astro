---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const events = [
  { name: "Spring Classic", window: "Last full weekend in April", href: "/events/spring-classic" },
  { name: "June Invitational", window: "Last full weekend in June", href: "/events/june-invitational" },
  { name: "Senior Invitational", window: "Late summer", href: "/events/senior-invitational" },
  { name: "Central Counties (CCGA)", window: "May 2 – Sept 27, 2026 (away matches at member clubs)", href: "/events/central-counties" },
  { name: "Fall Classic", window: "Late season (two-day weekend)", href: "/events/fall-classic" },
];
---

<BaseLayout title="Calendar" description="Calendar of events for American Legion Country Club.">
  <PageHero title="Calendar" subtitle="Live event calendar." />

  <section class="section">
    <div class="container">
      <div id="fb-root"></div>
      <script async defer crossorigin="anonymous" src="https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v19.0"></script>

      <div class="fb-calendar-wrap">
        <div
          class="fb-page"
          data-href="https://www.facebook.com/americanlegioncountryclub/"
          data-tabs="events"
          data-width="500"
          data-height="700"
          data-small-header="true"
          data-adapt-container-width="true"
          data-hide-cover="false"
          data-show-facepile="false"
        >
          <blockquote cite="https://www.facebook.com/americanlegioncountryclub/" class="fb-xfbml-parse-ignore">
            <a href="https://www.facebook.com/americanlegioncountryclub/">American Legion Country Club</a>
          </blockquote>
        </div>
      </div>
      <p><em>Events are pulled live from the club's Facebook Page — post or
      update an event there and it will appear here automatically. Manage
      events at
      <a href="https://www.facebook.com/americanlegioncountryclub/" target="_blank" rel="noopener">facebook.com/americanlegioncountryclub</a>.</em></p>

      <h2 style="margin-top:2.5rem;">Quick Reference</h2>
      <table>
        <thead><tr><th>Event</th><th>Approximate Window</th><th></th></tr></thead>
        <tbody>
          {events.map((e) => (
            <tr>
              <td>{e.name}</td>
              <td>{e.window}</td>
              <td><a href={e.href}>Details &rarr;</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<style>
  .fb-calendar-wrap {
    display: flex;
    justify-content: center;
    padding: 1rem;
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius);
    background: var(--color-off-white);
    overflow-x: auto;
  }
</style>
