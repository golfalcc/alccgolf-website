---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Thank You" description="Thanks for contacting American Legion Country Club.">
  <PageHero title="Thank You" subtitle="Your message has been sent." />
  <section class="section">
    <div class="container">
      <p>Thanks for reaching out — a member of the ALCC team will get back
      to you soon.</p>
      <a class="btn btn--red" href="/">Back to Home</a>
    </div>
  </section>
</BaseLayout>
