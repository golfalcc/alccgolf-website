---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Memberships" description="Membership applications at American Legion Country Club.">
  <PageHero title="Memberships" subtitle="Applications available now for the 2026 season." />

  <section class="section">
    <div class="container">
      <h2>2026 Membership Application</h2>
      <p>Golf, social, and add-on memberships for the 2026 season —
      including individual, family, retired, college, and junior golf
      rates, plus cart and locker add-ons. Download the application below,
      or stop by the pro shop or club office for a printed copy.</p>
      <a class="btn btn--red" href="/downloads/2026-alcc-membership-application.pdf" target="_blank" rel="noopener">
        Download the 2026 Membership Application (PDF)
      </a>

      <h2 style="margin-top:2.5rem;">American Legion Memorial Home Association Membership</h2>
      <p>A 2026 Golf Membership requires membership with American Legion
      Post #107 (unless you're a college student under 21 or a Junior Golf
      member). Download the Legion Home Association application below for
      Active Legionnaire, Associate, Sons of the American Legion, and
      Ladies Auxiliary membership.</p>
      <a class="btn btn--navy" href="/downloads/2026-legion-membership-application.pdf" target="_blank" rel="noopener">
        Download the Legion Membership Application (PDF)
      </a>

      <p style="margin-top:2.5rem;"><em>Questions about membership
      categories or pricing? </em><a href="/contact">Contact the club</a>.</p>
    </div>
  </section>
</BaseLayout>
