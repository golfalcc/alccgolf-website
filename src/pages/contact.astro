---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Contact Us" description="Contact American Legion Country Club.">
  <PageHero title="Contact Us" subtitle="We'd love to hear from you." />

  <section class="section">
    <div class="container contact-grid">
      <div>
        <h2>Get In Touch</h2>
        <p>If you have any questions, please fill out this form and we
        will get in touch with you as soon as possible. Alternatively, you
        can give us a call or drop by and visit us — we hope to see you
        soon!</p>

        <p><strong>Pro Shop:</strong> <a href="tel:18145424343">(814) 542-4343</a><br />
        <strong>Email:</strong> <a href="mailto:ALCCGOLF.18.2024@gmail.com">ALCCGOLF.18.2024@gmail.com</a><br />
        <strong>Address:</strong> ALCC, 1 Country Club Road, Mount Union, PA 17066</p>

        <p>
          <a href="https://www.facebook.com/americanlegioncountryclub/" target="_blank" rel="noopener">Facebook</a> &middot;
          <a href="https://www.instagram.com/alccgolfpa/" target="_blank" rel="noopener">Instagram</a> &middot;
          <a href="https://www.linkedin.com/company/alccmu" target="_blank" rel="noopener">LinkedIn</a>
        </p>
        <!-- Note: the club's site currently lists a few different contact
        emails across pages (ALCCGOLF.18.2024@gmail.com on this page,
        golf.alcc@gmail.com in the footer). Confirm which is authoritative
        and standardize before launch. -->
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thank-you"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <label for="name">Name</label>
        <input id="name" type="text" name="name" required />

        <label for="email">Email</label>
        <input id="email" type="email" name="email" required />

        <label for="phone">Phone</label>
        <input id="phone" type="tel" name="phone" />

        <label for="subject">Subject</label>
        <select id="subject" name="subject">
          <option>General Inquiry</option>
          <option>Membership</option>
          <option>Tee Times</option>
          <option>Event / Outing Booking</option>
          <option>Pro Shop</option>
        </select>

        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required></textarea>

        <button class="btn btn--red" type="submit">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2.5rem;
    align-items: start;
  }
  .contact-form { display: flex; flex-direction: column; gap: 0.35rem; }
  .contact-form label {
    font-family: var(--font-heading);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-blue);
    margin-top: 0.75rem;
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius);
  }
  .contact-form button { margin-top: 1.25rem; align-self: flex-start; }
  .hidden-field { display: none; }
  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
