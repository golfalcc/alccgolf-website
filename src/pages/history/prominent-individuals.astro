---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const entry = await getEntry('history', 'prominent-individuals');
const people = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <PageHero title="Prominent Figures in the History of the JVCC/ALCC" subtitle="The visionaries who shaped a century of Pennsylvania golf." />

  <section class="section">
    <div class="container narrative">
      <p>In the hallowed halls of Juniata Valley Colony Club and its
      transformation into the thriving American Legion Country Club, the
      narrative is woven not just by bricks and mortar but by the
      indelible contributions of visionary individuals who shaped its
      destiny. This page stands as a tribute to the luminaries who, with
      unwavering dedication and foresight, guided the evolution of this
      tranquil haven in the heart of Pennsylvania. Their stories, etched
      into the landscape, are the essence of the club's rich tapestry.</p>

      <p>We will be contributing to this page on an ongoing basis as we
      uncover more history. Select a profile below to read their full
      story.</p>
    </div>
  </section>

  <section class="section section--off-white">
    <div class="container">
      <span class="eyebrow">Meet the Figures</span>
      <h2>Prominent Individuals</h2>
      <div class="people-grid">
        {people.map((p) => (
          <a class="people-card" href={`/history/people/${p.slug}`}>
            <img class="people-card__photo" src={p.data.photo} alt={p.data.name} loading="lazy" />
            <h3>{p.data.name}</h3>
            <p class="people-card__role">{p.data.role}</p>
            {p.data.dates && <p class="people-card__dates">{p.data.dates}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .narrative { max-width: 780px; }
  .people-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 1.5rem;
  }
  .people-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: inherit;
    text-decoration: none;
  }
  .people-card__photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-white);
    box-shadow: var(--shadow-md);
    margin-bottom: 1rem;
    transition: transform 0.15s ease;
  }
  .people-card:hover .people-card__photo { transform: translateY(-4px); }
  .people-card h3 {
    font-size: 1.05rem;
    margin: 0 0 0.15rem;
  }
  .people-card__role {
    font-size: 0.85rem;
    color: var(--color-gray);
    margin: 0 0 0.15rem;
  }
  .people-card__dates {
    font-size: 0.8rem;
    color: var(--color-gray);
    margin: 0;
  }
  @media (max-width: 900px) {
    .people-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .people-grid { grid-template-columns: 1fr; }
  }
</style>
