---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const people = await getCollection('people');
  return people.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { name, role, dates, photo, summary } = entry.data;
---

<BaseLayout title={name} description={summary}>
  <section class="person-hero">
    <div class="container person-hero__inner">
      <img class="person-hero__photo" src={photo} alt={name} loading="lazy" />
      <div>
        <span class="eyebrow eyebrow--light">{role}</span>
        <h1>{name}</h1>
        {dates && <p class="person-hero__dates">{dates}</p>}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container person-content">
      <a class="back-link" href="/history/prominent-individuals">&larr; Back to Prominent Individuals</a>
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .person-hero {
    background: var(--color-blue-dark);
    color: var(--color-white);
    padding: 2.5rem 0;
  }
  .person-hero__inner {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .person-hero__photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-white);
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
  }
  .eyebrow--light { color: #FFD966; }
  .person-hero h1 { margin: 0.15rem 0; color: var(--color-white); }
  .person-hero__dates { margin: 0; color: var(--color-gray-light); }
  .person-content { max-width: 780px; }
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  @media (max-width: 600px) {
    .person-hero__inner { flex-direction: column; text-align: center; }
  }
</style>
