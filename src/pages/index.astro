---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const announcements = [
  { text: "Membership applications available for the 2026 season", href: "/memberships" },
  { text: "2026 tournament schedule is available through our Events portal", href: "/events" },
  { text: "Central Counties events for 2026 are scheduled — see the CCGA page", href: "/events/central-counties" },
  { text: "Interested in using ALCC as a venue? Contact Stefan at (814) 542-4343", href: "/contact" },
];

const quickLinks = [
  { title: "Golf", href: "/golf-course", description: "18 holes of classic Pennsylvania golf.", image: "/images/golf-course/course-1.webp" },
  { title: "Lounge", href: "/stonehouse-lounge", description: "The StoneHouse Lounge — food and drink with a view of the course.", image: "/images/lounge/stonehouse-logo.webp", imageFit: "contain", imageScale: 0.95 },
  { title: "History", href: "/history", description: "Decades of champions, records, and club lore.", image: "/images/history/colony-club-fairway-7.webp" },
  { title: "Spring Classic", href: "/events/spring-classic", description: "The season-opening team event.", image: "/images/spring-classic/logo.webp", imageFit: "contain" },
  { title: "Central Counties", href: "/events/central-counties", description: "CCGA series events hosted at ALCC.", image: "/images/central-counties/logo.webp", imageFit: "contain" },
  { title: "June Invitational", href: "/events/june-invitational", description: "A longstanding flighted stroke-play invitational.", image: "/images/june-invitational/2027.webp", imageFit: "contain" },
];
---

<BaseLayout title="Home" description="American Legion Country Club — golf course, StoneHouse Lounge, and event venue in Mount Union, PA.">
  <Hero
    eyebrow="Mount Union, Pennsylvania"
    title="Welcome to the American Legion Country Club"
    subtitle="Home to a century of Pennsylvania golf tradition."
    ctaLabel="See All Upcoming Events"
    ctaHref="/events"
    image="/images/home/hero-painting.webp"
  />

  <div class="announcement-bar">
    <div class="container">
      <ul class="announcement-bar__list">
        {announcements.map((a) => (
          <li><a href={a.href}>{a.text}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Explore the Club</span>
      <h2>Golf, Lounge & History</h2>
      <div class="grid grid--3">
        {quickLinks.map((q) => (
          <Card title={q.title} href={q.href} description={q.description} image={q.image} imageFit={q.imageFit} imageScale={q.imageScale} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--off-white">
    <div class="container weather-section">
      <span class="eyebrow">Course Conditions</span>
      <h2>Current Weather</h2>
      <div class="weather-widget-wrap">
        <a class="weatherwidget-io" href="https://forecast7.com/en/40d38n77d88/mount-union/?unit=us" data-label_1="MOUNT UNION" data-label_2="PENNSYLVANIA" data-theme="original">MOUNT UNION</a>
      </div>
    </div>
  </section>
  <script is:inline>!function(d,s,id){var js,fjs=d.getElementsByTagName(s)[0];if(!d.getElementById(id)){js=d.createElement(s);js.id=id;js.src='https://weatherwidget.io/js/widget.min.js';fjs.parentNode.insertBefore(js,fjs);}}(document,'script','weatherwidget-io-js');</script>

  <section class="section section--navy">
    <div class="container leadership">
      <div>
        <span class="eyebrow eyebrow--light">Club Leadership</span>
        <h2>Who Runs ALCC</h2>
        <ul class="leadership__list">
          <li><strong>General Manager:</strong> Stefan Morgan</li>
          <li><strong>Lounge Manager:</strong> Brandi Smith</li>
          <li><strong>Superintendent:</strong> Paul Smith</li>
          <li><strong>Major Tournament Director:</strong> Bruce Smith</li>
        </ul>
      </div>
      <div class="leadership__cta">
        <p>Questions about tee times, membership, or booking the club for an event?</p>
        <a class="btn btn--red" href="tel:18145424343">Call Now: (814) 542-4343</a>
        <a class="btn btn--outline" href="/contact">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .weather-section { text-align: center; }
  .weather-widget-wrap { max-width: 350px; margin: 1.5rem auto 0; }
  .eyebrow--light { color: #FFD966; }
  .leadership {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  .leadership__list { list-style: none; margin: 0; padding: 0; }
  .leadership__list li { margin-bottom: 0.5rem; }
  .leadership__cta { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; }
  @media (max-width: 800px) {
    .leadership { grid-template-columns: 1fr; }
  }
</style>
